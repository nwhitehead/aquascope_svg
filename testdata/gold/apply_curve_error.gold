```rust
fn main() /* L0 */  {

struct TestResult {
  scores: Vec<usize>,
  curve: Option<usize>
}

impl TestResult {
  pub fn get_curve(&self) -> &Option<usize> {
    &self.curve
  }

  pub fn apply_curve(&mut self) {
    if let Some(curve) = self.get_curve() {
      for score in self.scores.iter_mut() {
        *score += *curve;
      }
    }
  }
}

}```


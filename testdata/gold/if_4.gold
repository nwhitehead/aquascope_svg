fn foo(mut b: i32) /* L3 */  {
  let a = &mut b; /* L4 */ 

  if {
    *a += 1;
    let z = *a * 2;
    let q = *a / 2;
    (z + q - *a) * 3 > 100
  } {
    println!("{a}");
  } else {
    println!("{b}");
  } /* L5 */ 
} /* L6 */ 

fn main() /* L0 */  {
  let x = 12; /* L1 */ 
  foo(x); /* L2 */  /* L3 */  /* L4 */  /* L5 */  /* L6 */  /* L7 */ 
} /* L8 */ 

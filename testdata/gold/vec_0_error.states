```rust
use std::mem;

fn reverse(v: &mut Vec<i32>)  /* L3 */ {
  let n = v.len(); /* L4 */ 
  for i in 0 .. n / 2 {
    let a = &mut v[i];
    let b = &mut v[n - i - 1];
    mem::swap(a, b);
  } /* L5 */ 
} /* L6 */ 

fn main()  /* L0 */ {
    let mut a = vec![1, 2, 3]; /* L1 */ 
    reverse(&mut a); /* L2 */  /* L3 */  /* L4 */  /* L5 */  /* L6 */  /* L7 */ 
} /* L8 */ 
```

